---
import { siteConfig } from '../config/site';
import { byCategory, categoryLabel, type Category } from '../data/services';

const wa = `https://wa.me/${siteConfig.contact.whatsapp.primary.number}?text=${encodeURIComponent('Halo CargoPro, saya ingin bertanya.')}`;
const groups: Category[] = ['pengiriman', 'titip-beli', 'pembayaran'];
const company = [
  { href: '/tentang', label: 'Tentang Kami' },
  { href: '/layanan', label: 'Semua Layanan' },
  { href: '/lacak', label: 'Lacak Kiriman' },
  { href: '/insights', label: 'Insights' },
  { href: '/kontak', label: 'Kontak' },
];
const year = new Date().getFullYear();

const social = [
  { href: siteConfig.social.instagram, label: 'Instagram', d: 'M12 2.2c3.2 0 3.6 0 4.85.07 3.25.15 4.77 1.69 4.92 4.92.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.15 3.23-1.66 4.77-4.92 4.92-1.27.06-1.64.07-4.85.07s-3.58-.01-4.85-.07c-3.26-.15-4.77-1.7-4.92-4.92C2.06 15.58 2.05 15.2 2.05 12s.01-3.58.07-4.85C2.27 3.92 3.78 2.38 7.04 2.23 8.31 2.18 8.69 2.2 12 2.2zm0 3.65A6.15 6.15 0 1 0 12 18.15 6.15 6.15 0 0 0 12 5.85zm0 10.15A4 4 0 1 1 12 8a4 4 0 0 1 0 8zm6.4-10.4a1.44 1.44 0 1 0 0 2.88 1.44 1.44 0 0 0 0-2.88z' },
];
---

<footer class="bg-[#0b0c0f] text-white/70 relative border-t border-line/30 overflow-hidden">
  
  <!-- Ambient Background Glows -->
  <div class="absolute top-0 right-0 w-[800px] h-[800px] bg-[#e7c96a]/5 rounded-full blur-[150px] -translate-y-1/2 translate-x-1/3 pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-[600px] h-[600px] bg-orange/5 rounded-full blur-[120px] translate-y-1/3 -translate-x-1/4 pointer-events-none"></div>

  <div class="max-w-[1360px] mx-auto px-4 md:px-8 relative z-10">
    

    <!-- ── MIDDLE SECTION: 4-COLUMN GRID ─────────────────────────────── -->
    <div class="py-20 grid grid-cols-1 md:grid-cols-2 xl:grid-cols-[1.5fr_1fr_1fr_1.2fr] gap-12 lg:gap-16 border-b border-white/10">
      
      <!-- Column 1: Logo & Socials -->
      <div class="flex flex-col">
        <a href="/" class="inline-block mb-8" aria-label={`${siteConfig.name} — Beranda`}>
          <img src="/logo-cargopro-transparent-horizontal.png" alt={`Logo ${siteConfig.name}`} class="h-9 md:h-11 w-auto brightness-0 invert opacity-90 hover:opacity-100 transition-opacity" loading="lazy" decoding="async" />
        </a>
        <p class="text-[0.95rem] text-white/50 leading-relaxed mb-10 max-w-sm">
          Menyediakan solusi logistik terintegrasi untuk pengiriman kargo, titip beli, dan pembayaran supplier dari China ke Indonesia. Cepat, aman, dan transparan.
        </p>
        <div class="flex gap-4 mt-auto">
          {social.map((s) => (
            <a href={s.href} target="_blank" rel="noopener noreferrer" aria-label={s.label} class="grid place-items-center w-11 h-11 rounded-full bg-white/5 border border-white/10 text-white/60 hover:text-ink hover:bg-gradient-to-r hover:from-[#e7c96a] hover:to-[#b5952f] hover:border-transparent hover:-translate-y-1 transition-all duration-300 shadow-sm">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d={s.d}/></svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Column 2: Layanan -->
      <div>
        <p class="font-display font-bold text-white text-lg tracking-wide mb-8">Layanan Kami</p>
        <ul class="space-y-4">
          {groups.flatMap(g => byCategory(g)).map((s) => (
            <li>
              <a href={`/layanan/${s.slug}`} class="text-[0.95rem] text-white/50 hover:text-[#e7c96a] hover:translate-x-1 transition-all inline-block">
                {s.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Perusahaan -->
      <div>
        <p class="font-display font-bold text-white text-lg tracking-wide mb-8">Perusahaan</p>
        <ul class="space-y-4">
          {company.map((l) => (
            <li>
              <a href={l.href} class="text-[0.95rem] text-white/50 hover:text-[#e7c96a] hover:translate-x-1 transition-all inline-block">
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 4: Kontak -->
      <div>
        <p class="font-display font-bold text-white text-lg tracking-wide mb-8">Hubungi Kami</p>
        <ul class="space-y-6 text-[0.95rem] text-white/50">
          <li>
            <a href={wa} target="_blank" rel="noopener noreferrer" class="flex items-start gap-4 hover:text-[#e7c96a] transition-colors group">
              <div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center shrink-0 group-hover:bg-[#e7c96a]/10 transition-colors text-white/70 group-hover:text-[#e7c96a]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
              </div>
              <div class="pt-1.5 flex flex-col">
                <span class="text-xs uppercase tracking-wider text-white/40 font-bold mb-1">WhatsApp CS</span>
                <span class="font-medium text-white/80 group-hover:text-[#e7c96a] transition-colors">{siteConfig.contact.whatsapp.primary.display}</span>
              </div>
            </a>
          </li>
          <li>
            <a href={`mailto:${siteConfig.contact.email.cs}`} class="flex items-start gap-4 hover:text-[#e7c96a] transition-colors group">
              <div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center shrink-0 group-hover:bg-[#e7c96a]/10 transition-colors text-white/70 group-hover:text-[#e7c96a]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
              </div>
              <div class="pt-1.5 flex flex-col">
                <span class="text-xs uppercase tracking-wider text-white/40 font-bold mb-1">Email Corporate</span>
                <span class="font-medium text-white/80 group-hover:text-[#e7c96a] transition-colors break-all">{siteConfig.contact.email.cs}</span>
              </div>
            </a>
          </li>
          <li class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center shrink-0 text-white/70">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
            </div>
            <div class="pt-1.5 flex flex-col">
              <span class="text-xs uppercase tracking-wider text-white/40 font-bold mb-1">Jam Operasional</span>
              <span class="font-medium text-white/80">Sen–Jum: {siteConfig.contact.hours.weekday}</span>
            </div>
          </li>
        </ul>
      </div>

    </div>

    <!-- ── BOTTOM SECTION: COPYRIGHT ─────────────────────────────────── -->
    <div class="py-8 flex flex-col md:flex-row items-center justify-between gap-4 text-[0.85rem] text-white/40 font-medium">
      <p>© {year} <span class="text-white/70 font-bold">{siteConfig.name}</span>. Seluruh hak cipta dilindungi undang-undang.</p>
      <div class="flex items-center gap-6">
        <span class="hidden md:inline-block">Jasa Import & Forwarder Terpercaya</span>
        <a href="#" class="hover:text-white/80 transition-colors">Kebijakan Privasi</a>
      </div>
    </div>
    
  </div>
</footer>
