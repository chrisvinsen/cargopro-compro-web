---
import { siteConfig } from '../config/site';
import { services, byCategory, categoryLabel, type Category } from '../data/services';

const wa = `https://wa.me/${siteConfig.contact.whatsapp.primary.number}?text=${encodeURIComponent('Halo CargoPro, saya ingin konsultasi import dari China.')}`;

const groups: Category[] = ['pengiriman', 'titip-beli', 'pembayaran'];
const links = [
  { href: '/tentang', label: 'Tentang' },
  { href: '/lacak', label: 'Lacak' },
  { href: '/insights', label: 'Insights' },
  { href: '/kontak', label: 'Kontak' },
];
---

<header id="hdr" class="fixed top-0 inset-x-0 z-[100] bg-white/90 backdrop-blur-md border-b border-white/20 transition-all duration-300">
  <div class="shell flex items-center justify-between h-[84px] gap-4 relative">
    
    <!-- ── LOGO ────────────────────────────────────────────────────────── -->
    <a href="/" class="flex items-center shrink-0 group relative z-10" aria-label={`${siteConfig.name} — Beranda`}>
      <img src="/logo-cargopro-transparent-horizontal.png" alt={`Logo ${siteConfig.name}`} class="h-10 md:h-[46px] w-auto group-hover:opacity-80 transition-opacity" fetchpriority="high" decoding="async" />
    </a>

    <!-- ── DESKTOP NAV ─────────────────────────────────────────────────── -->
    <nav class="hidden lg:flex items-center gap-2 absolute left-1/2 -translate-x-1/2 h-full" aria-label="Navigasi utama">
      
      <!-- Layanan (Dropdown) -->
      <div class="group h-full flex items-center">
        <button class="flex items-center gap-1.5 px-4 py-2.5 text-[0.95rem] font-bold text-ink hover:text-orange transition-colors rounded-full hover:bg-orange/5" aria-haspopup="true" aria-expanded="false">
          Layanan
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true" class="transition-transform duration-300 group-hover:-rotate-180"><path d="m6 9 6 6 6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        
        <!-- Centered Floating Box Mega Menu -->
        <div class="invisible opacity-0 translate-y-4 group-hover:visible group-hover:opacity-100 group-hover:translate-y-0 group-focus-within:visible group-focus-within:opacity-100 group-focus-within:translate-y-0 transition-all duration-500 absolute left-1/2 -translate-x-1/2 top-full pt-4 before:content-[''] before:absolute before:top-0 before:left-0 before:right-0 before:h-4 z-50">
          
          <div class="w-[900px] bg-white/95 backdrop-blur-2xl border border-line/60 rounded-[40px] shadow-[0_30px_100px_-20px_rgba(0,0,0,0.15)] p-10 grid grid-cols-3 gap-10 relative overflow-hidden">
            <!-- Glow effect inside menu -->
            <div class="absolute top-0 right-0 w-[400px] h-[400px] bg-orange/5 rounded-full blur-[100px] pointer-events-none"></div>
            
            {groups.map((g) => (
              <div class="relative z-10 flex flex-col h-full">
                <p class="font-display font-bold text-xs uppercase tracking-[0.2em] text-orange mb-6 flex items-center gap-2 pb-4 border-b border-line/60">
                  <span class="w-1.5 h-1.5 rounded-full bg-orange shadow-[0_0_8px_rgba(249,115,22,0.6)]"></span>
                  {categoryLabel[g]}
                </p>
                <ul class="space-y-3 flex-1">
                  {byCategory(g).map((s) => (
                    <li>
                      <a href={`/layanan/${s.slug}`} class="group/link block rounded-2xl p-4 -mx-4 hover:bg-sand/80 border border-transparent hover:border-line/60 transition-all duration-300 relative overflow-hidden">
                        <div class="flex items-center justify-between mb-1 relative z-10">
                          <span class="block font-display font-bold text-ink text-[0.95rem] group-hover/link:text-orange transition-colors">{s.name}</span>
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-orange opacity-0 -translate-x-2 group-hover/link:opacity-100 group-hover/link:translate-x-0 transition-all duration-300"><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        </div>
                        <span class="block text-[0.8rem] text-muted leading-relaxed relative z-10">{s.tagline}</span>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>

        </div>
      </div>

      <!-- Other Links -->
      {links.map((l) => (
        <a href={l.href} class="relative px-4 py-2.5 text-[0.95rem] font-bold text-ink hover:text-orange transition-colors rounded-full hover:bg-orange/5">{l.label}</a>
      ))}
    </nav>

    <!-- ── CTA BUTTON & MOBILE TOGGLE ────────────────────────────────── -->
    <div class="flex items-center gap-2 sm:gap-3 relative z-10">
      <a href={wa} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-1.5 sm:gap-2 px-4 py-2 sm:px-6 sm:py-2.5 rounded-full bg-gradient-to-r from-[#e7c96a] to-[#b5952f] text-white font-bold hover:brightness-110 shadow-xl shadow-orange/20 hover:shadow-orange/30 hover:-translate-y-0.5 transition-all duration-300 text-xs sm:text-sm group">
        <span class="sm:hidden">Hitung Biaya</span>
        <span class="hidden sm:inline">Hitung Biaya</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="group-hover:translate-x-1 transition-transform sm:w-4 sm:h-4" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      
      <!-- Mobile Hamburger -->
      <button id="navToggle" class="lg:hidden flex items-center justify-center w-12 h-12 rounded-full bg-sand border border-line/60 text-ink hover:bg-orange/10 hover:text-orange transition-colors" aria-label="Buka menu" aria-expanded="false" aria-controls="mobilePanel">
        <svg id="navOpen" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
        <svg id="navClose" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" class="hidden" aria-hidden="true"><path d="M6 6l12 12M18 6 6 18"/></svg>
      </button>
    </div>
  </div>

  <!-- ── MOBILE PANEL ────────────────────────────────────────────────── -->
  <div id="mobilePanel" class="lg:hidden hidden border-t border-line/60 bg-white/95 backdrop-blur-2xl max-h-[calc(100dvh-84px)] overflow-y-auto animate-slide-down shadow-2xl relative">
    <div class="shell py-8 relative z-10">
      {groups.map((g) => (
        <div class="mb-8 bg-sand/30 p-6 rounded-[32px] border border-line/30">
          <p class="font-display font-bold text-xs uppercase tracking-[0.2em] text-orange mb-6 flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-orange"></span>
            {categoryLabel[g]}
          </p>
          <ul class="space-y-3">
            {byCategory(g).map((s) => (
              <li>
                <a href={`/layanan/${s.slug}`} class="flex items-center justify-between p-4 rounded-2xl bg-white shadow-sm border border-line/60 hover:border-orange/30 text-ink hover:text-orange transition-all">
                  <span class="font-bold text-[0.95rem]">{s.name}</span>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
      <div class="grid grid-cols-2 gap-4 mb-8">
        {links.map((l) => (
          <a href={l.href} class="flex items-center justify-center p-4 rounded-2xl bg-paper border border-line/60 shadow-sm text-ink hover:text-orange hover:border-orange/50 transition-all font-bold text-sm">{l.label}</a>
        ))}
      </div>
      <a href={wa} target="_blank" rel="noopener noreferrer" class="flex items-center justify-center gap-2 px-6 py-4 rounded-[20px] bg-gradient-to-r from-[#e7c96a] to-[#b5952f] text-white font-bold hover:brightness-110 shadow-xl shadow-orange/20 transition-all text-[0.95rem] w-full">
        Hitung Biaya
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
  </div>
</header>
<div class="h-[84px]" aria-hidden="true"></div>

<script is:inline>
  (() => {
    const hdr = document.getElementById('hdr');
    const onScroll = () => hdr && hdr.classList.toggle('shadow-[0_8px_30px_-18px_rgba(28,28,28,.15)]', window.scrollY > 8);
    window.addEventListener('scroll', onScroll, { passive: true }); onScroll();

    const btn = document.getElementById('navToggle');
    const panel = document.getElementById('mobilePanel');
    const open = document.getElementById('navOpen');
    const close = document.getElementById('navClose');
    btn && btn.addEventListener('click', () => {
      const isOpen = !panel.classList.contains('hidden');
      panel.classList.toggle('hidden');
      open.classList.toggle('hidden', !isOpen);
      close.classList.toggle('hidden', isOpen);
      btn.setAttribute('aria-expanded', String(!isOpen));
      btn.setAttribute('aria-label', isOpen ? 'Buka menu' : 'Tutup menu');
    });
    panel && panel.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', () => {
        panel.classList.add('hidden'); open.classList.remove('hidden'); close.classList.add('hidden');
        btn.setAttribute('aria-expanded', 'false');
      })
    });
  })();
</script>

<style>
  .animate-slide-down {
    animation: slideDown 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-20px) scale(0.98);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
</style>
