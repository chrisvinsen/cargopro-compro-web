---
import { siteConfig } from '../config/site';
interface Props { title?: string; text?: string; }
const {
  title = 'Siap Impor Barang dari China?',
  text = 'Konsultasikan kebutuhan impor Anda. Dapatkan estimasi biaya yang transparan dan solusi pengiriman yang sesuai.',
} = Astro.props;
const wa = `https://wa.me/${siteConfig.contact.whatsapp.primary.number}?text=${encodeURIComponent('Halo CargoPro, saya tertarik menggunakan layanan jasa import untuk bisnis saya. Boleh minta info lebih lanjut?')}`;
---
<section class="section">
  <div class="shell">
    <!-- Centralized Premium CTA -->
    <div class="relative overflow-hidden bg-gradient-to-br from-ink to-ink-2 text-white rounded-[40px] px-8 py-16 md:px-20 md:py-24 shadow-2xl text-center border border-white/5">
      <!-- Decorative Glow -->
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-2xl h-[400px] bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-orange/30 via-transparent to-transparent pointer-events-none"></div>
      
      <div class="relative z-10 max-w-3xl mx-auto flex flex-col items-center">
        <!-- Live Badge -->
        <div class="inline-flex items-center justify-center px-4 py-2 rounded-full bg-white/5 border border-white/10 text-[#d4af37] font-bold text-sm mb-8 backdrop-blur-sm shadow-sm">
          <span class="w-2 h-2 rounded-full bg-[#d4af37] mr-2 animate-pulse"></span>
          Konsultasi Gratis 24/7
        </div>

        <h2 class="font-display font-bold text-4xl md:text-5xl lg:text-6xl balance leading-tight mb-6 text-transparent bg-clip-text bg-gradient-to-r from-white to-white/80">
          {title}
        </h2>
        
        <p class="text-white/70 text-lg md:text-xl mb-10 max-w-2xl leading-relaxed">
          {text}
        </p>
        
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 w-full sm:w-auto">
          <a href={wa} target="_blank" rel="noopener noreferrer" class="btn btn--lg bg-gradient-to-r from-[#e7c96a] to-[#b5952f] text-white hover:brightness-110 hover:-translate-y-1 transition-all duration-300 border-0 shadow-xl shadow-orange/20 w-full sm:w-auto font-bold group flex items-center justify-center">
            Hubungi via WhatsApp
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="ml-2 group-hover:translate-x-1 transition-transform"><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="/layanan" class="btn btn--lg bg-white/5 hover:bg-white/10 text-white border border-white/10 backdrop-blur-sm w-full sm:w-auto transition-colors flex items-center justify-center">
            Lihat Detail Layanan
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
