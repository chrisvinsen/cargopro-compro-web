---
import { siteConfig } from '../config/site';
const wa = `https://wa.me/${siteConfig.contact.whatsapp.primary.number}?text=${encodeURIComponent('Halo CargoPro, saya ingin konsultasi import dari China.')}`;
---

<div class="fixed z-[120] bottom-4 right-4 md:bottom-8 md:right-8 flex items-center gap-6 md:gap-8 pointer-events-none">
  
  <!-- Bubble Text (Left) -->
  <a href={wa} target="_blank" rel="noopener noreferrer" class="relative pointer-events-auto bg-gradient-to-r from-[#2cd96b] to-[#1f9b5c] px-6 py-3.5 rounded-full shadow-[0_10px_25px_rgba(37,211,102,0.3)] hover:scale-105 hover:-translate-y-1 transition-transform duration-300 animate-bounce-subtle hidden sm:flex items-center">
    <p class="text-[0.95rem] font-display font-bold text-white tracking-wide whitespace-nowrap">Konsultasi Gratis Sekarang!</p>
    <!-- Tail (Smooth SVG arrow) -->
    <svg viewBox="0 0 10 16" class="absolute -right-2 top-1/2 -translate-y-1/2 w-2.5 h-4 text-[#1f9b5c]" fill="currentColor">
      <path d="M0 0 V 16 L 7.5 10.5 Q 10 8 7.5 5.5 Z" />
    </svg>
  </a>

  <!-- WhatsApp Icon with Rings (Right) -->
  <a
    href={wa}
    target="_blank"
    rel="noopener noreferrer"
    id="wafab"
    aria-label="Chat WhatsApp"
    class="pointer-events-auto relative flex items-center justify-center group w-14 h-14 md:w-[72px] md:h-[72px]"
  >
    <!-- Outer soft halo -->
    <div class="absolute inset-0 scale-[1.7] bg-[#25D366]/10 rounded-full animate-pulse-slow pointer-events-none"></div>
    
    <!-- Middle ring -->
    <div class="absolute inset-0 scale-[1.3] bg-[#25D366]/25 rounded-full pointer-events-none shadow-[0_0_20px_rgba(37,211,102,0.2)] group-hover:scale-[1.4] transition-transform duration-300"></div>
    
    <!-- Core button -->
    <div class="relative w-full h-full bg-gradient-to-br from-[#32d96f] to-[#128C7E] rounded-full flex items-center justify-center shadow-xl group-hover:scale-105 transition-transform duration-300 z-10">
      <svg width="34" height="34" viewBox="0 0 24 24" fill="white" aria-hidden="true" class="md:w-10 md:h-10"><path d="M17.47 14.38c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.16-.17.2-.35.22-.64.08-.3-.15-1.26-.46-2.39-1.48-.88-.79-1.48-1.76-1.65-2.06-.17-.3-.02-.46.13-.6.13-.14.3-.35.45-.52.15-.18.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.61-.92-2.21-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.79.37s-1.04 1.02-1.04 2.48 1.07 2.88 1.22 3.07c.15.2 2.1 3.2 5.08 4.49.71.3 1.26.49 1.69.63.71.22 1.36.19 1.87.12.57-.09 1.76-.72 2-1.41.25-.7.25-1.29.18-1.41-.07-.12-.27-.2-.57-.35M12.05 21.8h-.01a9.87 9.87 0 0 1-5.03-1.38l-.36-.21-3.74.98 1-3.65-.24-.37a9.86 9.86 0 0 1-1.51-5.26c0-5.45 4.44-9.88 9.89-9.88 2.64 0 5.12 1.03 6.99 2.9a9.82 9.82 0 0 1 2.89 6.99c0 5.45-4.44 9.88-9.89 9.88M20.46 3.49A11.82 11.82 0 0 0 12.05 0C5.5 0 .16 5.34.16 11.89c0 2.1.55 4.14 1.59 5.95L0 24l6.3-1.65a11.88 11.88 0 0 0 5.68 1.45h.01c6.55 0 11.89-5.34 11.89-11.89 0-3.18-1.24-6.16-3.42-8.42"/></svg>
    </div>
  </a>
</div>

<style>
  .animate-bounce-subtle {
    animation: bounceSubtle 3s infinite cubic-bezier(0.4, 0, 0.2, 1);
  }
  @keyframes bounceSubtle {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }
  
  .animate-pulse-slow {
    animation: pulseSlow 3s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
  @keyframes pulseSlow {
    0%, 100% { opacity: 0.1; }
    50% { opacity: 0.3; }
  }
</style>
