---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBand from '../components/CtaBand.astro';

const values = [
  { t: 'Transparansi 100%', d: 'Biaya pengiriman dan clearance dihitung jelas di awal. Tidak ada tagihan siluman di akhir.' },
  { t: 'Tepat Waktu', d: 'Jadwal pengiriman yang konsisten agar perputaran stok bisnis Anda tetap lancar.' },
  { t: 'Aman & Terpercaya', d: 'Setiap pengiriman barang ditangani secara profesional. Bebas dari rasa khawatir karena barang Anda pasti sampai dengan selamat.' },
  { t: 'Layanan Lengkap', d: 'Dari pengiriman LCL/FCL hingga titip beli di 1688 dan Taobao, kami siap bantu segalanya.' },
];

const coverage = ['Guangzhou', 'Yiwu', 'Shenzhen', 'Jakarta', 'Surabaya', 'Medan', 'Bandung', 'Makassar'];

const faqs = [];
---

<BaseLayout
  title="Tentang CargoPro — Jasa Import China & Forwarder Terpercaya"
  description="CargoPro hadir untuk mempermudah bisnis impor Anda. Layanan import door-to-door yang praktis, aman, dan 100% transparan."
  keywords="jasa import china, forwarder china indonesia, import door to door, jasa titip beli china, pengiriman kargo china"
  path="/tentang"
  preload="/images/hero-containers.jpg"
>
  <!-- ── SIMPLE HERO SECTION ──────────────────────────────────────── -->
  <section class="pt-28 md:pt-36 pb-12 md:pb-16 px-4 md:px-8 bg-paper overflow-hidden relative border-b border-line/30">
    
    <!-- Ambient Background Glows -->
    <div class="absolute top-0 right-1/4 w-[500px] h-[500px] bg-orange/5 rounded-full blur-[100px] -translate-y-1/2 pointer-events-none"></div>
    <div class="absolute bottom-0 left-1/4 w-[400px] h-[400px] bg-[#d4af37]/5 rounded-full blur-[100px] translate-y-1/2 pointer-events-none"></div>

    <div class="max-w-4xl mx-auto relative z-10 text-center fade-up">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/80 backdrop-blur-sm shadow-sm border border-orange/10 text-orange text-sm font-bold tracking-wider mb-6 uppercase">
        Tentang CargoPro
      </div>
      
      <h1 class="font-display font-black leading-[1.1] text-ink mb-6 text-[clamp(2.5rem,4vw,4rem)] tracking-tight">
        Mitra Logistik <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#e7c96a] to-[#b5952f]">Terpercaya Anda</span>
      </h1>
      
      <p class="text-muted text-lg md:text-xl font-medium leading-relaxed max-w-2xl mx-auto">
        Kami mengambil alih semua kerumitan impor Anda. Dari urusan pembayaran, negosiasi supplier, hingga proses custom clearance. <span class="font-bold text-ink">Fokus berjualan, biarkan kami yang mengurus pengirimannya.</span>
      </p>
    </div>
  </section>

  <!-- ── VISI & MISI (STICKY SCROLL) ──────────────────────────────────────── -->
  <section class="bg-paper py-20 md:py-32 relative">
    <div class="max-w-[1360px] mx-auto px-4 md:px-8">
      
      <div class="grid lg:grid-cols-[1fr_1.2fr] gap-12 lg:gap-16 items-start relative">
        
        <!-- Visi (Sticky Left) -->
        <div class="lg:sticky lg:top-32 bg-[#0f1115] text-white p-8 md:p-12 rounded-[40px] shadow-2xl overflow-hidden min-h-[400px] flex flex-col justify-center border border-white/10 group">
          <div class="absolute top-0 right-0 w-[400px] h-[400px] bg-[#e7c96a]/10 rounded-full blur-[80px] -translate-y-1/2 translate-x-1/3 pointer-events-none transition-transform duration-700 group-hover:scale-110"></div>
          
          <div class="relative z-10">
            <p class="font-display font-bold text-sm uppercase tracking-[0.2em] text-[#e7c96a] mb-6 flex items-center gap-3">
              <span class="w-2 h-2 rounded-full bg-[#e7c96a] animate-pulse"></span>
              Visi Utama
            </p>
            <h2 class="font-display font-black text-white text-[clamp(2rem,3.5vw,3rem)] leading-[1.1] tracking-tight mb-8">
              Menjadi mitra logistik <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#e7c96a] to-[#b5952f]">nomor satu</span> di Indonesia.
            </h2>
            <p class="text-white/70 text-lg leading-relaxed">
              Kami menjembatani pebisnis Indonesia dengan potensi pasar China tanpa batas, menghapus batasan jarak dengan layanan yang pasti dan terukur.
            </p>
          </div>
        </div>

        <!-- Misi (Scroll Right) -->
        <div class="flex flex-col gap-6 md:gap-8">
          <div class="mb-4 hidden lg:block">
            <h3 class="font-display font-black text-3xl text-ink">Misi Kami</h3>
            <p class="text-muted mt-2">Komitmen yang terus kami pegang teguh.</p>
          </div>
          
          <div class="bg-white/60 backdrop-blur-xl border border-line/60 p-8 md:p-10 rounded-[32px] shadow-sm hover:shadow-xl hover:border-orange/30 transition-all duration-300 group relative overflow-hidden">
            <div class="absolute -right-10 -top-10 w-40 h-40 bg-orange/5 rounded-full blur-[30px] group-hover:bg-orange/10 transition-colors"></div>
            <span class="font-display font-black text-6xl text-orange/10 group-hover:text-[#e7c96a]/30 transition-colors absolute top-8 right-8">01</span>
            <div class="relative z-10 max-w-[85%]">
              <h4 class="font-bold text-2xl mb-4 text-ink">Door-to-Door Praktis</h4>
              <p class="text-muted text-lg leading-relaxed">Menyediakan layanan pengiriman yang sangat praktis, mulai dari penerimaan di gudang China hingga diantar tepat ke depan pintu Anda.</p>
            </div>
          </div>
          
          <div class="bg-white/60 backdrop-blur-xl border border-line/60 p-8 md:p-10 rounded-[32px] shadow-sm hover:shadow-xl hover:border-orange/30 transition-all duration-300 group relative overflow-hidden">
            <div class="absolute -right-10 -top-10 w-40 h-40 bg-orange/5 rounded-full blur-[30px] group-hover:bg-orange/10 transition-colors"></div>
            <span class="font-display font-black text-6xl text-orange/10 group-hover:text-[#e7c96a]/30 transition-colors absolute top-8 right-8">02</span>
            <div class="relative z-10 max-w-[85%]">
              <h4 class="font-bold text-2xl mb-4 text-ink">Transparansi Mutlak</h4>
              <p class="text-muted text-lg leading-relaxed">Memberikan transparansi biaya secara total tanpa ada biaya siluman (hidden fees) sekecil apapun di akhir proses.</p>
            </div>
          </div>

          <div class="bg-white/60 backdrop-blur-xl border border-line/60 p-8 md:p-10 rounded-[32px] shadow-sm hover:shadow-xl hover:border-orange/30 transition-all duration-300 group relative overflow-hidden">
            <div class="absolute -right-10 -top-10 w-40 h-40 bg-orange/5 rounded-full blur-[30px] group-hover:bg-orange/10 transition-colors"></div>
            <span class="font-display font-black text-6xl text-orange/10 group-hover:text-[#e7c96a]/30 transition-colors absolute top-8 right-8">03</span>
            <div class="relative z-10 max-w-[85%]">
              <h4 class="font-bold text-2xl mb-4 text-ink">Keamanan Maksimal</h4>
              <p class="text-muted text-lg leading-relaxed">Menjamin keamanan maksimal untuk setiap kargo berharga Anda hingga tiba di alamat tujuan dengan sempurna.</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── PILAR LAYANAN (BENTO GRID) ──────────────────────────────────────── -->
  <section class="py-20 md:py-32 bg-sand/30 border-t border-line/50">
    <div class="max-w-[1360px] mx-auto px-4 md:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16 fade-up">
        <p class="font-display font-bold text-sm uppercase tracking-[0.2em] text-orange mb-4">Nilai Perusahaan</p>
        <h2 class="font-display font-black text-[clamp(2.5rem,4vw,3.5rem)] text-ink leading-[1.1] mb-6">Mengapa Memilih <span class="text-gradient-gold">CargoPro?</span></h2>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {values.map((v, i) => (
          <div class={`bg-white p-8 md:p-10 rounded-[40px] border border-line/60 hover:border-[#e7c96a]/50 shadow-sm hover:shadow-2xl hover:shadow-orange/10 transition-all duration-500 group fade-up d${i + 1} relative overflow-hidden ${i === 0 || i === 3 ? 'lg:col-span-2' : ''}`}>
            
            <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-bl from-orange/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            
            <div class="w-14 h-14 rounded-2xl bg-orange/5 flex items-center justify-center mb-8 text-orange font-black text-2xl group-hover:scale-110 group-hover:bg-gradient-to-br group-hover:from-[#e7c96a] group-hover:to-[#b5952f] group-hover:text-white group-hover:shadow-lg transition-all duration-300">
              0{i + 1}
            </div>
            <h3 class="font-display font-bold text-2xl mb-4 text-ink">{v.t}</h3>
            <p class="text-muted text-lg leading-relaxed relative z-10 max-w-xl" set:html={v.d}></p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── COVERAGE (ANIMATED MARQUEE) ──────────────────────────────────────── -->
  <section class="py-24 bg-[#0f1115] relative overflow-hidden my-12 mx-4 md:mx-8 rounded-[40px] md:rounded-[60px] shadow-2xl border border-white/5">
    <!-- Ambient Glows & Grid -->
    <div class="absolute inset-0 bg-[url('/images/pattern-dots.svg')] opacity-[0.03]"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-[600px] bg-[#e7c96a]/5 rounded-full blur-[120px] pointer-events-none"></div>
    
    <div class="relative z-10 text-center mb-16">
      <p class="font-display font-bold text-xs uppercase tracking-[0.2em] text-[#e7c96a] mb-4">Jangkauan Luas</p>
      <h2 class="font-display font-black text-4xl md:text-5xl lg:text-6xl text-white leading-tight mb-8">Dari China ke <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#e7c96a] to-[#b5952f]">Seluruh Nusantara</span></h2>
    </div>
    
    <!-- Animated Marquee -->
    <div class="w-full relative z-10 overflow-hidden py-8 mask-image-marquee">
      <div class="flex gap-6 w-max animate-marquee hover:[animation-play-state:paused]">
        <!-- Set 1 -->
        {coverage.map((c) => (
          <div class="bg-white/5 backdrop-blur-md border border-white/10 text-white font-bold rounded-full px-8 py-4 text-lg md:text-xl shadow-lg hover:border-[#e7c96a] hover:text-[#e7c96a] hover:-translate-y-1 hover:bg-[#e7c96a]/10 transition-all cursor-default flex items-center gap-3">
            <span class="w-2 h-2 rounded-full bg-[#e7c96a]"></span>
            {c}
          </div>
        ))}
        <!-- Set 2 (Duplicate for infinite loop) -->
        {coverage.map((c) => (
          <div class="bg-white/5 backdrop-blur-md border border-white/10 text-white font-bold rounded-full px-8 py-4 text-lg md:text-xl shadow-lg hover:border-[#e7c96a] hover:text-[#e7c96a] hover:-translate-y-1 hover:bg-[#e7c96a]/10 transition-all cursor-default flex items-center gap-3">
            <span class="w-2 h-2 rounded-full bg-[#e7c96a]"></span>
            {c}
          </div>
        ))}
      </div>
    </div>
    
  </section>

  <style>
    .mask-image-marquee {
      -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
      mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    }
    .animate-marquee {
      animation: marquee 30s linear infinite;
    }
    @keyframes marquee {
      0% { transform: translateX(0); }
      100% { transform: translateX(calc(-50% - 12px)); } /* 12px is half the gap */
    }
  </style>

  <CtaBand title="Siap memulai impor barang Anda?" />
</BaseLayout>
