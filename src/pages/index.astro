---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBand from '../components/CtaBand.astro';
import Faq from '../components/Faq.astro';
import { siteConfig } from '../config/site';
import { byCategory, categoryLabel, type Category } from '../data/services';

const wa = `https://wa.me/${siteConfig.contact.whatsapp.primary.number}?text=${encodeURIComponent('Halo CargoPro, saya tertarik menggunakan layanan jasa import untuk bisnis saya. Boleh minta info lebih lanjut?')}`;
const groups: Category[] = ['pengiriman', 'titip-beli', 'pembayaran'];

const steps = [
  { t: 'Transaksi Pembelian', d: 'Belanja di supplier pilihan Anda dan gunakan alamat gudang China serta kode marking khusus dari kami.' },
  { t: 'Kirim ke Gudang China', d: 'Supplier mengirim pesanan ke gudang kami. Anda cukup melampirkan invoice dan rincian barang.' },
  { t: 'Proses Pengiriman', d: 'Barang diberangkatkan ke Indonesia. Kami mengurus seluruh dokumen dan regulasi import untuk Anda.' },
  { t: 'Tiba di Jakarta', d: 'Setibanya di gudang Jakarta, kami akan menginformasikan kedatangan barang beserta tagihan ongkos kirim.' },
  { t: 'Bayar & Terima Beres', d: 'Selesaikan pembayaran, dan pesanan akan langsung diantar dengan aman ke alamat Anda.' },
];

const reasons = [
  { t: 'Terima Beres.', d: 'Fokus berjualan, biarkan kami yang mengurus seluruh proses pengiriman kargo Anda.' },
  { t: 'Transparansi', d: 'Tidak ada biaya siluman. Semua estimasi ongkos kirim disepakati di awal.' },
  { t: '100% Aman', d: 'Keamanan barang Anda adalah prioritas kami. Bebas resiko dan pengiriman lancar sampai tujuan.' },
];

const faqs = [
  { q: 'Apakah CargoPro melayani import untuk perusahaan (B2B)?', a: 'Sangat melayani. Kami menangani kargo besar (FCL/LCL) dengan sangat profesional.' },
  { q: 'Bagaimana sistem pembayaran ke supplier di China?', a: 'Layanan Titip Beli kami akan menalangi pembayaran. Jika sudah punya supplier, kami sedia Transfer RMB.' },
  { q: 'Berapa lama estimasi waktu pengiriman sampai Indonesia?', a: 'Udara 5-8 hari kerja. Laut (LCL/FCL) rata-rata 3-4 minggu bergantung pada jadwal kapal.' },
  { q: 'Apakah biaya yang ditawarkan sudah All-In?', a: 'Ya, mayoritas layanan kami adalah All-In yang mencakup ongkos kirim Internasional dan proses clearance.' },
];

const faqSchema = {
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
};
---

<BaseLayout
  title="Jasa Import China ke Indonesia Cepat & Aman | Forwarder Import"
  description="Fastindo Cargo: Jasa forwarding dan jasa import China ke Indonesia terpercaya. Layanan door to door, proses clearance, via laut dan udara. Import dari 1688, Alibaba, Taobao. Tanpa minimum pembelian. Konsultasi gratis!"
  keywords="jasa import china, forwarder china indonesia, jasa import terpercaya, cargo laut china indonesia, importir barang china, b2b import china"
  path="/"
  preload="/images/hero-cargo-ship.jpg"
  jsonld={faqSchema}
>
  <!-- ── REDESIGNED HERO ──────────────────────────────────────── -->
  <section class="pt-8 md:pt-24 pb-4 lg:pb-8 px-4 md:px-8 bg-paper overflow-hidden relative">
    
    <!-- Right-Aligned Background Image & Gradient Overlays (Desktop Only) -->
    <div class="absolute inset-y-0 right-0 w-full lg:w-[65%] xl:w-[65%] z-0 pointer-events-none hidden lg:block">
      <img src="/images/hero-main.webp" alt="Hero Background" class="w-full h-full object-cover object-center lg:object-left" fetchpriority="high" decoding="async" />
      
      <!-- Gradient overlay to blend the left edge of the image into the paper background -->
      <div class="absolute inset-y-0 left-0 w-48 md:w-64 bg-gradient-to-r from-paper via-paper/80 to-transparent"></div>
      
      <!-- Top gradient for smooth transition from the header -->
      <div class="absolute inset-x-0 top-0 h-24 sm:h-32 lg:h-40 bg-gradient-to-b from-paper via-paper/60 to-transparent"></div>
      
      <!-- Bottom gradient for smooth transition to the section below -->
      <div class="absolute inset-x-0 bottom-0 h-24 sm:h-32 lg:h-40 bg-gradient-to-t from-paper via-paper/90 md:via-paper/80 to-transparent"></div>
    </div>



    <div class="max-w-7xl mx-auto relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-8 items-center">
        
        <!-- Left Column: Content -->
        <div class="flex flex-col items-start text-left fade-up">
          
          <!-- Badge -->
          <div class="inline-block px-4 py-1.5 rounded-full bg-gradient-to-r from-[#e7c96a] to-[#b5952f] text-white text-xs font-bold tracking-wider mb-6 uppercase shadow-md">
            Door-to-Door Import Specialist
          </div>
          
          <!-- Main Heading -->
          <h1 class="relative z-20 font-display font-black leading-[1.1] text-ink mb-6 max-w-2xl text-[2.8rem] sm:text-[3.5rem] lg:text-[4rem] xl:text-[4.5rem] tracking-tight drop-shadow-sm">
            IMPORT CHINA <br />
            TANPA <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#e7c96a] via-[#d4af37] to-[#b5952f]">RIBET.</span>
          </h1>
          
          <!-- Description -->
          <p class="text-muted text-base sm:text-lg md:text-xl font-medium leading-relaxed max-w-xl mb-4 relative z-10">
            CargoPro membantu Anda import dari China dengan layanan <span class="font-bold text-ink">ALL-IN Door-to-Door</span>. Aman, cepat, dan terpercaya.
          </p>
          
          <!-- CTA Buttons -->
          <div class="flex flex-row gap-2 sm:gap-4 w-full sm:w-auto mb-10 z-20 relative">
            <a href={wa} target="_blank" rel="noopener noreferrer" class="btn btn--lg bg-gradient-to-r from-[#e7c96a] to-[#b5952f] text-white hover:brightness-110 hover:-translate-y-1 border-0 shadow-xl shadow-orange/20 flex flex-row items-center justify-center gap-1.5 sm:gap-4 px-2 sm:px-6 py-3 w-[55%] sm:w-auto rounded-xl group transition-all duration-300">
              <svg class="w-5 h-5 sm:w-7 sm:h-7 shrink-0 group-hover:scale-110 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
              <div class="text-left">
                <div class="sm:hidden font-bold text-[13px] leading-tight">Konsultasi Gratis</div>
                <div class="hidden sm:block">
                  <div class="font-bold text-lg leading-tight">Konsultasi Gratis</div>
                  <div class="text-xs opacity-80 font-medium">Chat via WhatsApp</div>
                </div>
              </div>
            </a>
            
            <a href="/lacak" class="btn btn--lg bg-white border border-line text-ink hover:border-orange hover:shadow-md flex flex-row items-center justify-center gap-1.5 sm:gap-4 px-2 sm:px-6 py-3 w-[45%] sm:w-auto rounded-xl transition-all group">
              <svg class="w-5 h-5 sm:w-7 sm:h-7 shrink-0 text-muted group-hover:text-orange transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                <circle cx="12" cy="10" r="3" />
              </svg>
              <div class="text-left">
                <div class="sm:hidden font-bold text-[13px] leading-tight group-hover:text-orange transition-colors">Live Tracking</div>
                <div class="hidden sm:block">
                  <div class="font-bold text-lg leading-tight group-hover:text-orange transition-colors">Live Tracking</div>
                  <div class="text-xs text-muted font-medium">Pantau Status Barang</div>
                </div>
              </div>
            </a>
          </div>

          <!-- Mobile Inline Image (Mobile Only) -->
          <div class="block lg:hidden w-[100vw] relative left-1/2 -translate-x-1/2 -mt-52 mb-4 overflow-hidden pointer-events-none z-0">
            <img src="/images/hero-main.webp" alt="Hero Background Mobile" class="w-full min-h-[480px] h-auto object-cover object-center" fetchpriority="high" decoding="async" />
            <div class="absolute inset-x-0 top-0 h-48 bg-gradient-to-b from-paper via-paper/70 to-transparent"></div>
            <div class="absolute inset-x-0 bottom-0 h-28 bg-gradient-to-t from-paper via-paper/60 to-transparent"></div>
          </div>

          <!-- Checklist -->
          <ul class="grid grid-cols-2 sm:flex sm:flex-col gap-2 sm:gap-3 -mt-12 sm:mt-0 mb-10 relative z-20">
            {['Door to Door ALL-IN', 'SEA & AIR Freight', 'Pembayaran RMB', 'Supplier Sourcing'].map((item) => (
              <li class="flex items-center gap-1.5 sm:gap-3 text-ink font-medium text-[13px] sm:text-lg leading-tight">
                <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 sm:w-6 sm:h-6 text-[#d4af37] shrink-0">
                  <circle cx="12" cy="12" r="10" fill="currentColor" fill-opacity="0.2"/>
                  <path d="M8 12.5L10.5 15L16 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>

          <!-- Trust / Social Proof -->
          <div class="flex flex-col gap-3">
            <div class="flex items-center gap-4">
              <div class="flex -space-x-3">
                {[
                  '/logo-cargopro-circle.png',
                  '/images/service-jasa-belanja.jpg',
                  '/images/hero-china-shopping.webp'
                ].map((src) => (
                  <img src={src} alt="Importir Indonesia" class="w-10 h-10 rounded-full border-2 border-white shadow-sm object-cover bg-white" loading="lazy" />
                ))}
              </div>
              <div class="flex flex-col">
                <div class="flex gap-1 text-[#d4af37]">
                  {[...Array(5)].map(() => (
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                  ))}
                </div>
                <span class="text-sm text-muted font-medium mt-0.5">Dipercaya 500+ Importir di Indonesia</span>
              </div>
            </div>
            
            <div class="inline-flex items-center gap-2 bg-gradient-to-r from-[#e7c96a]/10 to-[#b5952f]/10 border border-[#d4af37]/20 rounded-full px-3 py-1.5 w-max shadow-sm backdrop-blur-sm">
              <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 text-[#d4af37] shrink-0">
                <circle cx="12" cy="12" r="10" fill="currentColor" fill-opacity="0.2"/>
                <path d="M8 12.5L10.5 15L16 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span class="text-[13px] font-bold text-[#b5952f]">Import Lebih Tenang Bersama CargoPro</span>
            </div>
          </div>
          
        </div>
        
        <!-- Right Column: Empty, allows background image to be seen on desktop -->
        <div class="hidden lg:block min-h-[400px]"></div>

      </div>

      <!-- ── TRUST BADGES BAR ──────────────────────────────────────── -->
      <div class="mt-10 bg-white/95 backdrop-blur-md rounded-2xl shadow-xl shadow-ink/5 border border-line/50 p-6 md:p-8 relative z-20">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8 divide-none lg:divide-x divide-line/50">
          
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-full bg-sand flex items-center justify-center shrink-0">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-ink"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
            </div>
            <div>
              <h4 class="font-bold text-ink mb-0.5 leading-tight text-sm lg:text-base">Aman & Bergaransi</h4>
              <p class="text-xs text-muted">Dilindungi penuh</p>
            </div>
          </div>
          
          <div class="flex items-center gap-4 lg:px-6">
            <div class="w-12 h-12 rounded-full bg-sand flex items-center justify-center shrink-0">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-ink"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
            </div>
            <div>
              <h4 class="font-bold text-ink mb-0.5 leading-tight text-sm lg:text-base">Tepat Waktu</h4>
              <p class="text-xs text-muted">Estimasi jelas</p>
            </div>
          </div>
          
          <div class="flex items-center gap-4 lg:px-6">
            <div class="w-12 h-12 rounded-full bg-sand flex items-center justify-center shrink-0">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-ink"><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/></svg>
            </div>
            <div>
              <h4 class="font-bold text-ink mb-0.5 leading-tight text-sm lg:text-base">Fast Response</h4>
              <p class="text-xs text-muted">Respon cepat</p>
            </div>
          </div>
          
          <div class="flex items-center gap-4 lg:px-6">
            <div class="w-12 h-12 rounded-full bg-sand flex items-center justify-center shrink-0">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-ink"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
            </div>
            <div>
              <h4 class="font-bold text-ink mb-0.5 leading-tight text-sm lg:text-base">Door-to-Door</h4>
              <p class="text-xs text-muted">Layanan All-In</p>
            </div>
          </div>

        </div>
      </div>

    </div>
  </section>





  <!-- ── STATS SECTION ──────────────────────────────────────── -->
  <section class="pb-16 pt-8 px-4 md:px-8 bg-paper relative z-20">
    <div class="max-w-[1360px] mx-auto bg-ink rounded-[24px] p-6 md:p-8 lg:p-10 shadow-2xl relative overflow-hidden">
      <!-- Subtle glow -->
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-full bg-gradient-to-r from-transparent via-orange/5 to-transparent pointer-events-none"></div>

      <div class="relative z-10 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8 divide-y sm:divide-y-0 sm:divide-x divide-white/10">
        
        <!-- Stat 1 -->
        <div class="flex items-center gap-4 pt-4 sm:pt-0 sm:px-4 lg:px-6 first:pt-0 first:px-0">
          <div class="w-14 h-14 flex items-center justify-center shrink-0">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#e7c96a" stroke-width="1.5"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
          </div>
          <div>
            <h4 class="font-bold text-white text-xl lg:text-2xl leading-tight mb-1 tracking-tight">10.000+</h4>
            <p class="text-sm md:text-base text-white/70 font-medium">Shipment Berhasil</p>
          </div>
        </div>

        <!-- Stat 2 -->
        <div class="flex items-center gap-4 pt-4 sm:pt-0 sm:px-4 lg:px-6">
          <div class="w-14 h-14 flex items-center justify-center shrink-0">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#e7c96a" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <div>
            <h4 class="font-bold text-white text-xl lg:text-2xl leading-tight mb-1 tracking-tight">500+</h4>
            <p class="text-sm md:text-base text-white/70 font-medium">Importir Terpercaya</p>
          </div>
        </div>

        <!-- Stat 3 -->
        <div class="flex items-center gap-4 pt-4 sm:pt-0 sm:px-4 lg:px-6">
          <div class="w-14 h-14 flex items-center justify-center shrink-0">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#e7c96a" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          </div>
          <div>
            <h4 class="font-bold text-white text-xl lg:text-2xl leading-tight mb-1 tracking-tight">Seluruh Indonesia</h4>
            <p class="text-sm md:text-base text-white/70 font-medium">Jangkauan Pengiriman</p>
          </div>
        </div>

        <!-- Stat 4 -->
        <div class="flex items-center gap-4 pt-4 sm:pt-0 sm:px-4 lg:px-6">
          <div class="w-14 h-14 flex items-center justify-center shrink-0">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#e7c96a" stroke-width="1.5"><path d="M3 21h18"/><path d="M3 7v14"/><path d="M21 7v14"/><path d="M3 7l9-5 9 5"/><path d="M12 11v10"/><path d="M9 21v-4a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v4"/><circle cx="8" cy="13" r="1" fill="#e7c96a" stroke="none"/><circle cx="16" cy="13" r="1" fill="#e7c96a" stroke="none"/><circle cx="8" cy="17" r="1" fill="#e7c96a" stroke="none"/><circle cx="16" cy="17" r="1" fill="#e7c96a" stroke="none"/></svg>
          </div>
          <div>
            <h4 class="font-bold text-white text-xl lg:text-2xl leading-tight mb-1 tracking-tight">Gudang China</h4>
            <p class="text-sm md:text-base text-white/70 font-medium">Guangzhou & Yiwu</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── SERVICES GRID ─────────────────────────────── -->
  <section class="section bg-paper relative overflow-hidden">
    <!-- Decorative Background Glow -->
    <div class="absolute top-1/2 left-0 w-[500px] h-[500px] bg-orange/5 rounded-full blur-[100px] -translate-y-1/2 pointer-events-none"></div>

    <div class="shell relative z-10">
      <div class="flex flex-col sm:flex-row items-start sm:items-end justify-between mb-10 fade-up">
        <div class="max-w-2xl">
          <p class="kicker mb-3">Solusi Logistik Anda</p>
          <h2 class="h-xl balance">Daftar Layanan <span class="text-gradient-gold">Import dari China</span></h2>
        </div>
        </div>

      <div class="flex flex-nowrap md:grid md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 overflow-x-auto md:overflow-x-visible snap-x snap-mandatory md:snap-none pb-12 pt-4 hide-scrollbar -mx-4 px-4 md:mx-0 md:px-0 fade-up">
          
          <!-- Service 1: LCL -->
          <a href="/layanan/kargo-laut-lcl" class="w-[85vw] sm:w-[380px] md:w-auto shrink-0 md:shrink snap-start group block relative focus-visible:outline-none">
            <div class="bg-white rounded-[32px] p-4 border border-line hover:border-orange/30 shadow-sm hover:shadow-xl hover:shadow-orange/10 transition-all duration-500 h-full flex flex-col">
              <div class="h-[240px] rounded-[24px] overflow-hidden mb-6 relative">
                <img src="/images/service-sea-lcl.jpg" width="400" height="300" loading="lazy" decoding="async" alt="Layanan pengiriman kargo laut LCL" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                <div class="absolute inset-0 bg-gradient-to-t from-ink/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                <div class="absolute bottom-4 right-4 w-12 h-12 bg-white/20 backdrop-blur-md border border-white/30 rounded-full flex items-center justify-center text-white opacity-0 group-hover:opacity-100 transform translate-y-4 group-hover:translate-y-0 transition-all duration-500">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </div>
              </div>
              <div class="px-2 pb-2 flex-1 flex flex-col">
                <h3 class="font-display font-bold text-2xl mb-3 text-ink group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-[#e7c96a] group-hover:to-[#b5952f] transition-all">Sea Freight LCL</h3>
                <p class="text-muted text-[0.95rem] leading-relaxed flex-1">Solusi konsolidasi untuk importir dengan volume kecil hingga menengah. Bayar hanya sebesar ruang yang dipakai.</p>
              </div>
            </div>
          </a>

          <!-- Service 2: FCL -->
          <a href="/layanan/kargo-laut-fcl" class="w-[85vw] sm:w-[380px] md:w-auto shrink-0 md:shrink snap-start group block relative focus-visible:outline-none">
            <div class="bg-white rounded-[32px] p-4 border border-line hover:border-orange/30 shadow-sm hover:shadow-xl hover:shadow-orange/10 transition-all duration-500 h-full flex flex-col">
              <div class="h-[240px] rounded-[24px] overflow-hidden mb-6 relative">
                <img src="/images/service-sea-fcl.jpg" width="400" height="300" loading="lazy" decoding="async" alt="Layanan pengiriman kargo laut FCL" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                <div class="absolute inset-0 bg-gradient-to-t from-ink/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                <div class="absolute bottom-4 right-4 w-12 h-12 bg-white/20 backdrop-blur-md border border-white/30 rounded-full flex items-center justify-center text-white opacity-0 group-hover:opacity-100 transform translate-y-4 group-hover:translate-y-0 transition-all duration-500">
