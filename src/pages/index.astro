---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBand from '../components/CtaBand.astro';
import Faq from '../components/Faq.astro';
import { siteConfig } from '../config/site';
import { byCategory, categoryLabel, type Category } from '../data/services';

const wa = `https://wa.me/${siteConfig.contact.whatsapp.primary.number}?text=${encodeURIComponent('Halo CargoPro, saya tertarik menggunakan layanan jasa import untuk bisnis saya. Boleh minta info lebih lanjut?')}`;
const groups: Category[] = ['pengiriman', 'titip-beli', 'pembayaran'];

const steps = [
  { t: 'Transaksi Pembelian', d: 'Belanja di supplier pilihan Anda dan gunakan alamat gudang China serta kode marking khusus dari kami.' },
  { t: 'Kirim ke Gudang China', d: 'Supplier mengirim pesanan ke gudang kami. Anda cukup melampirkan invoice dan rincian barang.' },
  { t: 'Proses Pengiriman', d: 'Barang diberangkatkan ke Indonesia. Kami mengurus seluruh dokumen dan regulasi import untuk Anda.' },
  { t: 'Tiba di Jakarta', d: 'Setibanya di gudang Jakarta, kami akan menginformasikan kedatangan barang beserta tagihan ongkos kirim.' },
  { t: 'Bayar & Terima Beres', d: 'Selesaikan pembayaran, dan pesanan akan langsung diantar dengan aman ke alamat Anda.' },
];

const reasons = [
  { t: 'Terima Beres.', d: 'Fokus berjualan, biarkan kami yang mengurus seluruh proses pengiriman kargo Anda.' },
  { t: 'Transparansi', d: 'Tidak ada biaya siluman. Semua estimasi ongkos kirim disepakati di awal.' },
  { t: '100% Aman', d: 'Keamanan barang Anda adalah prioritas kami. Bebas resiko dan pengiriman lancar sampai tujuan.' },
];

const faqs = [
  { q: 'Apakah CargoPro melayani import untuk perusahaan (B2B)?', a: 'Sangat melayani. Kami menangani kargo besar (FCL/LCL) dengan sangat profesional.' },
  { q: 'Bagaimana sistem pembayaran ke supplier di China?', a: 'Layanan Titip Beli kami akan menalangi pembayaran. Jika sudah punya supplier, kami sedia Transfer RMB.' },
  { q: 'Berapa lama estimasi waktu pengiriman sampai Indonesia?', a: 'Udara 5-8 hari kerja. Laut (LCL/FCL) rata-rata 3-4 minggu bergantung pada jadwal kapal.' },
  { q: 'Apakah biaya yang ditawarkan sudah All-In?', a: 'Ya, mayoritas layanan kami adalah All-In yang mencakup ongkos kirim Internasional dan proses clearance.' },
];

const faqSchema = {
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
};
---

<BaseLayout
  title="Jasa Import China ke Indonesia Cepat & Aman | Forwarder Import"
  description="Fastindo Cargo: Jasa forwarding dan jasa import China ke Indonesia terpercaya. Layanan door to door, proses clearance, via laut dan udara. Import dari 1688, Alibaba, Taobao. Tanpa minimum pembelian. Konsultasi gratis!"
  keywords="jasa import china, forwarder china indonesia, jasa import terpercaya, cargo laut china indonesia, importir barang china, b2b import china"
  path="/"
  preload="/images/hero-cargo-ship.jpg"
  jsonld={faqSchema}
>
  <!-- ── CENTERED HERO ──────────────────────────────────────── -->
  <section class="pt-12 md:pt-20 pb-0 px-4 md:px-8 bg-paper overflow-hidden relative">
    
    <!-- Ambient Background Glows -->
    <div class="absolute top-0 right-1/4 w-[600px] h-[600px] bg-orange/10 rounded-full blur-[100px] -translate-y-1/2 pointer-events-none"></div>
    <div class="absolute bottom-0 left-1/4 w-[500px] h-[500px] bg-[#d4af37]/10 rounded-full blur-[100px] translate-y-1/2 pointer-events-none"></div>

    <div class="max-w-5xl mx-auto relative z-10 flex flex-col items-center text-center fade-up">
      
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/80 backdrop-blur-sm shadow-sm border border-orange/20 text-orange text-sm font-bold tracking-wider mb-8 uppercase">
        <span class="w-2 h-2 rounded-full bg-orange animate-pulse"></span>
        100% Cepat & Aman
      </div>
      
      <!-- Main Heading -->
      <h1 class="font-display font-black leading-[1.1] text-ink mb-4 sm:mb-6 max-w-4xl">
        <span class="text-[1.8rem] min-[400px]:text-[2.2rem] sm:text-[clamp(2.5rem,6vw,5rem)] tracking-tight block"><span class="hidden sm:inline">Jasa </span>Forwarder Import</span>
        <span class="text-[2rem] min-[400px]:text-[2.5rem] sm:text-[clamp(2.8rem,6.5vw,5.5rem)] tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-[#e7c96a] via-[#d4af37] to-[#b5952f] block mt-1 sm:mt-2">China - Indonesia</span>
      </h1>
      
      <!-- Description -->
      <p class="text-muted text-sm min-[400px]:text-base sm:text-lg md:text-xl font-medium leading-relaxed max-w-2xl mx-auto mb-8 sm:mb-10">
        Cargo Pro membantu impor barang dari China ke Indonesia secara <span class="font-bold text-ink">ALL-IN Door-to-Door</span>. Mulai dari pencarian supplier, pembayaran, hingga barang tiba di gudang Anda dengan aman.
      </p>
      
      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 w-full sm:w-auto mb-8 md:mb-12 z-20 relative">
        <a href={wa} target="_blank" rel="noopener noreferrer" class="btn btn--lg bg-gradient-to-r from-[#e7c96a] to-[#b5952f] text-ink hover:text-white border-0 shadow-xl shadow-orange/20 w-full sm:w-auto font-bold group flex items-center justify-center">
          Mulai Konsultasi Gratis
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="ml-2 group-hover:translate-x-1 transition-transform"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/layanan" class="btn btn--lg bg-white border border-line text-ink font-bold hover:border-orange hover:text-orange hover:shadow-md w-full sm:w-auto transition-all">
          Lihat Layanan Kami
        </a>
      </div>

      <!-- Hero Image Collage (Horizontal Fan) -->
      <div class="relative w-full max-w-5xl mx-auto h-[250px] sm:h-[300px] md:h-[380px] lg:h-[420px] flex items-end justify-center -mt-4 z-10">
        
        <!-- Left Image (Plane) -->
        <div class="absolute left-[2%] md:left-[8%] bottom-[5%] w-[40%] md:w-[35%] aspect-[4/3] rounded-[24px] overflow-hidden shadow-2xl border-4 md:border-8 border-white z-10 -rotate-6 hover:rotate-0 hover:z-40 transition-all duration-500 ease-out group translate-x-4 md:translate-x-10">
          <img src="/images/service-sea-lcl.jpg" alt="Pesawat kargo" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" decoding="async" />
        </div>
        
        <!-- Main Center Image (Ship) -->
        <div class="absolute bottom-0 w-[55%] md:w-[45%] aspect-[4/3] rounded-[32px] overflow-hidden shadow-2xl border-4 md:border-8 border-white z-30 hover:-translate-y-4 transition-all duration-500 ease-out group">
          <img src="/images/service-sea-fcl.jpg" alt="Kapal kargo laut" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" fetchpriority="high" decoding="async" />
          
          <!-- Floating Trust Badge -->
          <div class="absolute top-4 right-4 bg-white/90 backdrop-blur-md py-2 px-4 rounded-full shadow-lg z-30 hidden md:flex items-center gap-2 border border-white/50">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="3"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>
            <span class="font-bold text-ink text-xs">Door to Door</span>
          </div>
        </div>

        <!-- Right Image (Warehouse) -->
        <div class="absolute right-[2%] md:right-[8%] bottom-[10%] w-[35%] md:w-[30%] aspect-[4/3] rounded-[20px] overflow-hidden shadow-2xl border-4 md:border-8 border-white z-20 rotate-6 hover:rotate-0 hover:z-40 transition-all duration-500 ease-out group -translate-x-4 md:-translate-x-10">
          <img src="/images/hero-cargo-plane.webp" alt="Gudang logistik" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" decoding="async" />
        </div>

      </div>

    </div>
  </section>

  <!-- ── REDESIGNED LOGO MARQUEE ──────────────────────────────────────── -->
  <section class="py-10 md:py-16 bg-paper overflow-hidden">
    <div class="max-w-[1360px] mx-auto px-4 lg:px-8">
      <div class="flex flex-col items-center">
        <p class="font-display text-xs md:text-sm font-bold uppercase tracking-[0.2em] text-muted mb-8 text-center">Layanan Import Barang dari Marketplace China</p>
        
        <div class="w-full bg-sand/50 rounded-[32px] border border-line/50 p-6 md:p-8 relative">
          <!-- Gradient Masks -->
          <div class="absolute inset-y-0 left-0 w-16 md:w-32 bg-gradient-to-r from-sand/50 to-transparent z-10 rounded-l-[32px] pointer-events-none"></div>
          <div class="absolute inset-y-0 right-0 w-16 md:w-32 bg-gradient-to-l from-sand/50 to-transparent z-10 rounded-r-[32px] pointer-events-none"></div>
          
          <div class="marquee-container" style="mask-image: none; -webkit-mask-image: none;">
            <div class="marquee-content">
              <!-- Taobao -->
              <img src="/images/logo-taobao.png" alt="Logo Taobao Marketplace" class="h-6 md:h-8 w-auto object-contain mix-blend-multiply opacity-80 hover:opacity-100 transition-opacity" width="120" height="32" loading="lazy" decoding="async" />
              <!-- 1688 -->
              <img src="/images/logo-1688.png" alt="Logo 1688 Wholesale" class="h-6 md:h-8 w-auto object-contain mix-blend-multiply opacity-80 hover:opacity-100 transition-opacity" width="120" height="32" loading="lazy" decoding="async" />
              <!-- Alibaba -->
              <img src="/images/logo-alibaba.png" alt="Logo Alibaba B2B" class="h-6 md:h-8 w-auto object-contain mix-blend-multiply opacity-80 hover:opacity-100 transition-opacity" width="120" height="32" loading="lazy" decoding="async" />
              <!-- Tmall -->
              <div class="flex items-center gap-2 text-ink-2/40 font-display font-extrabold text-lg md:text-xl tracking-tight">
                <span>Tmall <span class="font-normal text-sm opacity-60">天猫</span></span>
              </div>
              <!-- JD -->
              <img src="/images/logo-jdcom.png" alt="Logo JD.com" class="h-6 md:h-8 w-auto object-contain mix-blend-multiply opacity-80 hover:opacity-100 transition-opacity" width="120" height="32" loading="lazy" decoding="async" />
              <!-- AliExpress -->
              <img src="/images/logo-aliexpress.png" alt="Logo AliExpress" class="h-6 md:h-8 w-auto object-contain mix-blend-multiply opacity-80 hover:opacity-100 transition-opacity" width="120" height="32" loading="lazy" decoding="async" />
              <!-- Made in China -->
              <div class="flex items-center gap-2 text-ink-2/40 font-display font-extrabold text-md md:text-lg tracking-tight">
                <span class="border-2 border-ink-2/20 px-1.5 py-0.2 rounded text-[10px] font-bold">MIC</span>
                <span>Made-in-China</span>
              </div>
              
              <!-- Duplicate for infinite loop -->
              <!-- Taobao -->
              <img src="/images/logo-taobao.png" alt="Logo Taobao Marketplace" class="h-6 md:h-8 w-auto object-contain mix-blend-multiply opacity-80 hover:opacity-100 transition-opacity" width="120" height="32" loading="lazy" decoding="async" />
              <!-- 1688 -->
              <img src="/images/logo-1688.png" alt="Logo 1688 Wholesale" class="h-6 md:h-8 w-auto object-contain mix-blend-multiply opacity-80 hover:opacity-100 transition-opacity" width="120" height="32" loading="lazy" decoding="async" />
              <!-- Alibaba -->
              <img src="/images/logo-alibaba.png" alt="Logo Alibaba B2B" class="h-6 md:h-8 w-auto object-contain mix-blend-multiply opacity-80 hover:opacity-100 transition-opacity" width="120" height="32" loading="lazy" decoding="async" />
              <!-- Tmall -->
              <div class="flex items-center gap-2 text-ink-2/40 font-display font-extrabold text-lg md:text-xl tracking-tight">
                <span>Tmall <span class="font-normal text-sm opacity-60">天猫</span></span>
              </div>
              <!-- JD -->
              <img src="/images/logo-jdcom.png" alt="Logo JD.com" class="h-6 md:h-8 w-auto object-contain mix-blend-multiply opacity-80 hover:opacity-100 transition-opacity" width="120" height="32" loading="lazy" decoding="async" />
              <!-- AliExpress -->
              <img src="/images/logo-aliexpress.png" alt="Logo AliExpress" class="h-6 md:h-8 w-auto object-contain mix-blend-multiply opacity-80 hover:opacity-100 transition-opacity" width="120" height="32" loading="lazy" decoding="async" />
              <!-- Made in China -->
              <div class="flex items-center gap-2 text-ink-2/40 font-display font-extrabold text-md md:text-lg tracking-tight">
                <span class="border-2 border-ink-2/20 px-1.5 py-0.2 rounded text-[10px] font-bold">MIC</span>
                <span>Made-in-China</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── REDESIGNED FEATURES SECTION ──────────────────────────────────────── -->
  <section class="section bg-paper">
    <div class="shell">
      <div class="text-center max-w-2xl mx-auto mb-12 lg:mb-16 fade-up">
        <h2 class="h-xl balance mb-4">Mengapa Memilih Jasa Impor China <span class="text-orange">CargoPro?</span></h2>
        <p class="text-muted text-lg">Keunggulan layanan kami untuk memudahkan bisnis Anda.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
        {reasons.map((r, i) => (
          <div class="panel p-8 md:p-10 bg-sand/30 hover:bg-white border border-line hover:border-orange/30 transition-all duration-300 lift flex flex-col items-start fade-up group" class:list={[`d${i+1}`]}>
            <div class="w-16 h-16 rounded-2xl bg-white shadow-sm flex items-center justify-center mb-6 text-orange group-hover:scale-110 transition-transform duration-300">
              {i === 0 && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>}
              {i === 1 && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>}
              {i === 2 && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>}
            </div>
            <h3 class="font-display font-bold text-xl mb-3 text-ink group-hover:text-orange transition-colors">{r.t}</h3>
            <p class="text-muted leading-relaxed">{r.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── REDESIGNED STATS SECTION ──────────────────────────────────────── -->
  <section class="pb-16 pt-8 px-4 md:px-8 bg-paper">
    <div class="max-w-[1360px] mx-auto bg-ink rounded-[32px] md:rounded-[40px] p-10 md:p-16 relative overflow-hidden shadow-2xl">
      <!-- Ambient Glows -->
      <div class="absolute top-0 right-1/4 w-96 h-96 bg-orange/20 rounded-full blur-[100px] pointer-events-none"></div>
      <div class="absolute bottom-0 left-1/4 w-96 h-96 bg-blue-500/10 rounded-full blur-[100px] pointer-events-none"></div>
      
      <div class="relative z-10 grid grid-cols-2 lg:grid-cols-4 gap-y-12 gap-x-8 text-center divide-y-0 lg:divide-x divide-white/10">
        <!-- Stat 1 -->
        <div class="px-4 fade-up d1">
          <p class="font-display font-black text-5xl md:text-6xl text-transparent bg-clip-text bg-gradient-to-r from-white to-white/70 tracking-tight mb-3">10.000<span class="text-gradient-gold">+</span></p>
          <p class="text-sm md:text-base uppercase tracking-widest text-white/60 font-bold">Pengiriman Sukses</p>
        </div>
        <!-- Stat 2 -->
        <div class="px-4 border-l-0 sm:border-l border-white/5 fade-up d2">
          <p class="font-display font-black text-5xl md:text-6xl text-transparent bg-clip-text bg-gradient-to-r from-white to-white/70 tracking-tight mb-3">99<span class="text-gradient-gold">%</span></p>
          <p class="text-sm md:text-base uppercase tracking-widest text-white/60 font-bold">Barang Sampai Aman</p>
        </div>
        <!-- Stat 3 -->
        <div class="px-4 border-t lg:border-t-0 border-white/5 pt-8 lg:pt-0 fade-up d3">
          <p class="font-display font-black text-5xl md:text-6xl text-transparent bg-clip-text bg-gradient-to-r from-white to-white/70 tracking-tight mb-3">1000<span class="text-gradient-gold">+</span></p>
          <p class="text-sm md:text-base uppercase tracking-widest text-white/60 font-bold">Importir Kerjasama</p>
        </div>
        <!-- Stat 4 -->
        <div class="px-4 border-t lg:border-t-0 border-white/5 pt-8 lg:pt-0 border-l-0 sm:border-l border-white/5 fade-up d4">
          <p class="font-display font-black text-5xl md:text-6xl text-transparent bg-clip-text bg-gradient-to-r from-white to-white/70 tracking-tight mb-3">24<span class="text-gradient-gold">/</span>7</p>
          <p class="text-sm md:text-base uppercase tracking-widest text-white/60 font-bold">Layanan Responsif</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── SERVICES GRID ─────────────────────────────── -->
  <section class="section bg-paper relative overflow-hidden">
    <!-- Decorative Background Glow -->
    <div class="absolute top-1/2 left-0 w-[500px] h-[500px] bg-orange/5 rounded-full blur-[100px] -translate-y-1/2 pointer-events-none"></div>

    <div class="shell relative z-10">
      <div class="flex flex-col sm:flex-row items-start sm:items-end justify-between mb-10 fade-up">
        <div class="max-w-2xl">
          <p class="kicker mb-3">Solusi Logistik Anda</p>
          <h2 class="h-xl balance">Daftar Layanan <span class="text-gradient-gold">Import dari China</span></h2>
        </div>
        </div>

      <div class="flex flex-nowrap md:grid md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 overflow-x-auto md:overflow-x-visible snap-x snap-mandatory md:snap-none pb-12 pt-4 hide-scrollbar -mx-4 px-4 md:mx-0 md:px-0">
          
          <!-- Service 1: LCL -->
          <a href="/layanan/kargo-laut-lcl" class="w-[85vw] sm:w-[380px] md:w-auto shrink-0 md:shrink snap-start group block relative focus-visible:outline-none fade-up d1">
            <div class="bg-white rounded-[32px] p-4 border border-line hover:border-orange/30 shadow-sm hover:shadow-xl hover:shadow-orange/10 transition-all duration-500 h-full flex flex-col">
              <div class="h-[240px] rounded-[24px] overflow-hidden mb-6 relative">
                <img src="/images/service-sea-lcl.jpg" width="400" height="300" loading="lazy" decoding="async" alt="Layanan pengiriman kargo laut LCL" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                <div class="absolute inset-0 bg-gradient-to-t from-ink/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                <div class="absolute bottom-4 right-4 w-12 h-12 bg-white/20 backdrop-blur-md border border-white/30 rounded-full flex items-center justify-center text-white opacity-0 group-hover:opacity-100 transform translate-y-4 group-hover:translate-y-0 transition-all duration-500">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </div>
              </div>
              <div class="px-2 pb-2 flex-1 flex flex-col">
                <h3 class="font-display font-bold text-2xl mb-3 text-ink group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-[#e7c96a] group-hover:to-[#b5952f] transition-all">Sea Freight LCL</h3>
                <p class="text-muted text-[0.95rem] leading-relaxed flex-1">Solusi konsolidasi untuk importir dengan volume kecil hingga menengah. Bayar hanya sebesar ruang yang dipakai.</p>
              </div>
            </div>
          </a>

          <!-- Service 2: FCL -->
          <a href="/layanan/kargo-laut-fcl" class="w-[85vw] sm:w-[380px] md:w-auto shrink-0 md:shrink snap-start group block relative focus-visible:outline-none fade-up d2">
            <div class="bg-white rounded-[32px] p-4 border border-line hover:border-orange/30 shadow-sm hover:shadow-xl hover:shadow-orange/10 transition-all duration-500 h-full flex flex-col">
              <div class="h-[240px] rounded-[24px] overflow-hidden mb-6 relative">
                <img src="/images/service-sea-fcl.jpg" width="400" height="300" loading="lazy" decoding="async" alt="Layanan pengiriman kargo laut FCL" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                <div class="absolute inset-0 bg-gradient-to-t from-ink/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                <div class="absolute bottom-4 right-4 w-12 h-12 bg-white/20 backdrop-blur-md border border-white/30 rounded-full flex items-center justify-center text-white opacity-0 group-hover:opacity-100 transform translate-y-4 group-hover:translate-y-0 transition-all duration-500">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </div>
              </div>
              <div class="px-2 pb-2 flex-1 flex flex-col">
                <h3 class="font-display font-bold text-2xl mb-3 text-ink group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-[#e7c96a] group-hover:to-[#b5952f] transition-all">Sea Freight FCL</h3>
                <p class="text-muted text-[0.95rem] leading-relaxed flex-1">Ditujukan untuk importir skala besar yang membutuhkan efisiensi biaya maksimal. Satu kontainer penuh eksklusif.</p>
              </div>
            </div>
          </a>

          <!-- Service 3: Air Freight -->
          <a href="/layanan/kargo-udara" class="w-[85vw] sm:w-[380px] md:w-auto shrink-0 md:shrink snap-start group block relative focus-visible:outline-none fade-up d3">
            <div class="bg-white rounded-[32px] p-4 border border-line hover:border-orange/30 shadow-sm hover:shadow-xl hover:shadow-orange/10 transition-all duration-500 h-full flex flex-col">
              <div class="h-[240px] rounded-[24px] overflow-hidden mb-6 relative">
                <img src="/images/service-air-freight.jpg" width="400" height="300" loading="lazy" decoding="async" alt="Layanan pengiriman kargo udara express" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
                <div class="absolute inset-0 bg-gradient-to-t from-ink/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                <div class="absolute bottom-4 right-4 w-12 h-12 bg-white/20 backdrop-blur-md border border-white/30 rounded-full flex items-center justify-center text-white opacity-0 group-hover:opacity-100 transform translate-y-4 group-hover:translate-y-0 transition-all duration-500">
