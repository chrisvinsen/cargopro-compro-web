---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config/site';

const num = siteConfig.contact.whatsapp.primary.number;
const wa = `https://wa.me/${num}?text=${encodeURIComponent('Halo CargoPro, saya ingin konsultasi.')}`;
const mapsLink = siteConfig.contact.address.gmaps;

const channels = [
  {
    label: 'WhatsApp',
    value: siteConfig.contact.whatsapp.primary.display,
    note: 'Respon tercepat pada jam kerja',
    href: wa, external: true,
    svg: '<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>',
  },
  {
    label: 'Email',
    value: siteConfig.contact.email.cs,
    note: 'Untuk B2B / Kemitraan',
    href: `mailto:${siteConfig.contact.email.cs}`, external: false,
    svg: '<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>',
  },
  {
    label: 'Instagram',
    value: '@cargopro.id',
    note: 'Update & info terbaru',
    href: siteConfig.social.instagram, external: true,
    svg: '<rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>',
  },
];
---

<BaseLayout
  title="Kontak CargoPro — Konsultasi Import China"
  description="Hubungi CargoPro via WhatsApp, email, atau Instagram. Konsultasikan kebutuhan import China Anda — tim kami siap membantu pada jam kerja."
  keywords="kontak cargo pro, konsultasi import china, hubungi forwarder china"
  path="/kontak"
>
  <!-- ── HERO SECTION ────────────────────────────────────────────────── -->
  <section class="pt-28 md:pt-36 pb-16 bg-paper px-4 md:px-8 overflow-hidden relative">
    <div class="absolute top-0 right-1/4 w-[400px] h-[400px] bg-orange/5 rounded-full blur-[100px] -translate-y-1/2 pointer-events-none"></div>
    <div class="absolute bottom-0 left-1/4 w-[300px] h-[300px] bg-[#d4af37]/5 rounded-full blur-[100px] translate-y-1/2 pointer-events-none"></div>

    <div class="max-w-[1360px] mx-auto text-center relative z-10 fade-up">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/80 backdrop-blur-sm shadow-sm border border-orange/10 text-orange text-sm font-bold tracking-wider mb-6 uppercase">
        Layanan Pelanggan
      </div>
      <h1 class="font-display font-black leading-[1.05] text-ink text-[clamp(2.5rem,5vw,4.5rem)] tracking-tight mb-6">
        Hubungi <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#e7c96a] to-[#b5952f]">CargoPro</span>
      </h1>
      <p class="text-muted text-lg md:text-xl font-medium leading-relaxed max-w-2xl mx-auto">
        Punya pertanyaan soal tarif, jalur, atau prosesnya? Kirim pesan — kami bantu dari awal sampai barang tiba dengan aman.
      </p>
    </div>
  </section>

  <!-- ── MAIN CONTENT (BENTO + FORM) ─────────────────────────────────── -->
  <section class="pb-24 md:pb-32 bg-paper px-4 md:px-8">
    <div class="max-w-[1360px] mx-auto grid lg:grid-cols-[1fr_1.1fr] gap-10 lg:gap-16 items-start">
      
      <!-- LEFT: Bento Grid Info -->
      <div class="grid grid-cols-2 gap-4 lg:gap-6 fade-up d1">
        
        <!-- WhatsApp (Full Width) -->
        <a href={channels[0].href} target="_blank" rel="noopener noreferrer" class="col-span-2 bg-gradient-to-br from-orange/10 via-orange/5 to-transparent p-8 md:p-10 rounded-[32px] md:rounded-[40px] border border-orange/20 hover:border-orange/50 hover:shadow-2xl hover:shadow-orange/10 transition-all duration-500 group relative overflow-hidden">
          <div class="absolute -right-10 -top-10 w-40 h-40 bg-orange/20 rounded-full blur-[40px] group-hover:bg-orange/30 transition-colors duration-500"></div>
          
          <div class="flex items-start justify-between mb-16 relative z-10">
            <span class="grid place-items-center w-16 h-16 rounded-2xl bg-white text-orange shadow-sm group-hover:bg-gradient-to-br group-hover:from-[#e7c96a] group-hover:to-[#b5952f] group-hover:text-white transition-all duration-300">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={channels[0].svg}></svg>
            </span>
            <span class="w-10 h-10 rounded-full bg-white/50 flex items-center justify-center text-orange group-hover:bg-white group-hover:scale-110 transition-all">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </div>
          <div class="relative z-10">
            <p class="font-display font-bold text-sm uppercase tracking-[0.15em] text-orange mb-2">{channels[0].label}</p>
            <h3 class="font-display font-black text-3xl md:text-4xl text-ink mb-2">{channels[0].value}</h3>
            <p class="text-muted text-lg">{channels[0].note}</p>
          </div>
        </a>

        <!-- Email (Half Width) -->
        <a href={channels[1].href} class="col-span-1 bg-white p-6 md:p-8 rounded-[32px] border border-line/60 hover:border-orange/30 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group flex flex-col justify-between aspect-square">
          <span class="w-12 h-12 rounded-xl bg-orange/5 text-orange flex items-center justify-center mb-6 group-hover:bg-orange group-hover:text-white transition-colors">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={channels[1].svg}></svg>
          </span>
          <div>
            <p class="font-display font-bold text-xs uppercase tracking-[0.1em] text-muted mb-1">{channels[1].label}</p>
            <h3 class="font-display font-bold text-lg md:text-xl text-ink break-all group-hover:text-orange transition-colors">{channels[1].value}</h3>
            <p class="text-[0.85rem] text-muted mt-2 hidden sm:block">{channels[1].note}</p>
          </div>
        </a>

        <!-- Instagram (Half Width) -->
        <a href={channels[2].href} target="_blank" rel="noopener noreferrer" class="col-span-1 bg-white p-6 md:p-8 rounded-[32px] border border-line/60 hover:border-orange/30 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group flex flex-col justify-between aspect-square">
          <span class="w-12 h-12 rounded-xl bg-orange/5 text-orange flex items-center justify-center mb-6 group-hover:bg-gradient-to-br group-hover:from-[#e7c96a] group-hover:to-[#b5952f] group-hover:text-white transition-colors">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={channels[2].svg}></svg>
          </span>
          <div>
            <p class="font-display font-bold text-xs uppercase tracking-[0.1em] text-muted mb-1">{channels[2].label}</p>
            <h3 class="font-display font-bold text-lg md:text-xl text-ink group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-[#e7c96a] group-hover:to-[#b5952f] transition-all">{channels[2].value}</h3>
            <p class="text-[0.85rem] text-muted mt-2 hidden sm:block">{channels[2].note}</p>
          </div>
        </a>

        <!-- Jam Operasional (Full Width Dark Box) -->
        <div class="col-span-2 bg-[#0f1115] p-8 md:p-10 rounded-[32px] md:rounded-[40px] border border-white/10 text-white relative overflow-hidden group mt-2">
          <div class="absolute inset-0 bg-[url('/images/pattern-dots.svg')] opacity-[0.05]"></div>
          <div class="absolute top-0 right-0 w-64 h-64 bg-[#e7c96a]/10 rounded-full blur-[80px] pointer-events-none"></div>
          
          <div class="relative z-10 flex flex-col md:flex-row gap-8 justify-between">
            <div class="flex-1">
              <p class="font-display font-bold text-sm uppercase tracking-[0.2em] text-[#e7c96a] mb-6 flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-[#e7c96a] animate-pulse"></span>
                Jam Operasional
              </p>
              <dl class="space-y-4">
                <div class="flex justify-between items-center border-b border-white/10 pb-3">
                  <dt class="text-white/60">Senin – Jumat</dt>
                  <dd class="font-display font-bold text-lg">{siteConfig.contact.hours.weekday}</dd>
                </div>
                <div class="flex justify-between items-center border-b border-white/10 pb-3">
                  <dt class="text-white/60">Sabtu</dt>
                  <dd class="font-display font-bold text-lg">{siteConfig.contact.hours.saturday}</dd>
                </div>
                <div class="flex justify-between items-center">
                  <dt class="text-white/60">Minggu</dt>
                  <dd class="font-display font-bold text-lg">{siteConfig.contact.hours.sunday}</dd>
                </div>
              </dl>
            </div>
            
            <div class="md:w-[200px] shrink-0 border-t md:border-t-0 md:border-l border-white/10 pt-6 md:pt-0 md:pl-8 flex flex-col justify-end">
              <p class="text-white/60 text-sm mb-4 leading-relaxed">Kantor Pusat:<br/>{siteConfig.contact.address.street}, {siteConfig.contact.address.city}</p>
              <a href={mapsLink} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm font-display font-bold text-[#e7c96a] hover:text-white transition-colors group/map">
                Buka di Maps
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="group-hover/map:translate-x-1 transition-transform"><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            </div>
          </div>
        </div>

      </div>

      <!-- RIGHT: Contact Form (Premium Frost Effect) -->
      <div class="bg-white p-8 md:p-12 rounded-[40px] shadow-2xl shadow-ink/5 border border-line/50 relative fade-up d2 lg:sticky lg:top-32">
        <div class="absolute top-0 right-0 w-32 h-32 bg-orange/5 rounded-bl-[100px] pointer-events-none"></div>
        
        <h2 class="font-display font-black text-3xl text-ink mb-2">Kirim Pesan</h2>
        <p class="text-muted text-[0.95rem] mb-10 leading-relaxed">Isi detail kebutuhan Anda di bawah ini, dan sistem kami akan merangkumnya langsung ke WhatsApp CS kami.</p>
        
        <form id="kontakForm" class="space-y-6" novalidate data-wa={num}>
          <div class="space-y-2">
            <label for="f-nama" class="block text-sm font-bold text-ink tracking-wide">Nama Lengkap <span class="text-orange">*</span></label>
            <input id="f-nama" name="nama" type="text" required autocomplete="name" placeholder="Misal: Budi Santoso" class="w-full bg-sand/30 border border-line/60 rounded-2xl px-5 py-4 text-ink placeholder:text-muted/50 focus:bg-white focus:border-orange/50 focus:ring-4 focus:ring-orange/10 transition-all outline-none" />
          </div>
          
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="space-y-2">
              <label for="f-wa" class="block text-sm font-bold text-ink tracking-wide">Nomor WhatsApp <span class="text-orange">*</span></label>
              <input id="f-wa" name="wa" type="tel" required autocomplete="tel" placeholder="08xxxxxxxxxx" class="w-full bg-sand/30 border border-line/60 rounded-2xl px-5 py-4 text-ink placeholder:text-muted/50 focus:bg-white focus:border-orange/50 focus:ring-4 focus:ring-orange/10 transition-all outline-none" />
            </div>
            <div class="space-y-2">
              <label for="f-email" class="block text-sm font-bold text-ink tracking-wide">Email <span class="text-muted font-normal">(Opsional)</span></label>
              <input id="f-email" name="email" type="email" autocomplete="email" placeholder="email@perusahaan.com" class="w-full bg-sand/30 border border-line/60 rounded-2xl px-5 py-4 text-ink placeholder:text-muted/50 focus:bg-white focus:border-orange/50 focus:ring-4 focus:ring-orange/10 transition-all outline-none" />
            </div>
          </div>
          
          <div class="space-y-2">
            <label for="f-pesan" class="block text-sm font-bold text-ink tracking-wide">Detail Kebutuhan <span class="text-orange">*</span></label>
            <textarea id="f-pesan" name="pesan" rows="4" required placeholder="Ceritakan jenis barang yang ingin diimpor, berat estimasi, layanan yang diinginkan, atau pertanyaan Anda..." class="w-full bg-sand/30 border border-line/60 rounded-2xl px-5 py-4 text-ink placeholder:text-muted/50 focus:bg-white focus:border-orange/50 focus:ring-4 focus:ring-orange/10 transition-all resize-none outline-none"></textarea>
          </div>
          
          <button type="submit" class="w-full bg-gradient-to-r from-[#e7c96a] to-[#b5952f] text-white hover:brightness-110 font-bold text-lg py-4 rounded-2xl shadow-xl shadow-orange/20 hover:shadow-orange/30 hover:-translate-y-1 transition-all duration-300 flex items-center justify-center gap-2 group mt-2">
            Kirim via WhatsApp
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="group-hover:translate-x-1 transition-transform"><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          
          <p class="text-[0.75rem] text-muted text-center pt-2">Dengan mengirim pesan, Anda menyetujui kebijakan privasi CargoPro.</p>
        </form>
      </div>
      
    </div>
  </section>

  <script is:inline>
    (() => {
      const f = document.getElementById('kontakForm');
      if (!f) return;
      f.addEventListener('submit', (e) => {
        e.preventDefault();
        const num = f.getAttribute('data-wa');
        const get = (id) => (document.getElementById(id)?.value || '').trim();
        const nama = get('f-nama'), wa = get('f-wa'), email = get('f-email'), pesan = get('f-pesan');
        if (!nama || !wa || !pesan) { f.reportValidity(); return; }
        const lines = [
          '*Pesan dari website CargoPro*',
          '———',
          `Nama: ${nama}`,
          `WhatsApp: ${wa}`,
          email ? `Email: ${email}` : '',
          '———',
          'Pesan:',
          pesan,
        ].filter(Boolean);
        window.open(`https://wa.me/${num}?text=${encodeURIComponent(lines.join('\n'))}`, '_blank');
      });
    })();
  </script>
</BaseLayout>
